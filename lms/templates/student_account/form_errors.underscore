<div class="<%- jsHook %> status submission-error">
<h1>MESSAGE</h1>
<img src="<%= static_url('images/login-error.png') %>" alt="Error Icon" class="error-icon" />
    <h4 class="message-title"><%- title %></h4>
    <ul class="message-copy">
        <%= HtmlUtils.ensureHtml(messagesHtml) %>
    </ul>
</div>
